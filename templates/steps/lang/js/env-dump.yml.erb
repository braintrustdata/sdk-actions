<%#
  Prints environment diagnostics (Node/npm/pnpm versions, the configured
  registry, the package.json version) to help debug a failed release. Run from
  the package root.

  @param working_directory [String] expr for the package root.  Default: ${{ inputs.working_directory }}
-%>
- name: Dump JavaScript environment
  shell: bash
  working-directory: <%= locals.fetch(:working_directory) { "${{ inputs.working_directory }}" } %>
  run: |
    echo "=== Node environment ==="
    node --version
    npm --version
    echo "=== pnpm ==="
    pnpm --version || echo "(unavailable)"
    echo "=== Registry ==="
    npm config get registry
    echo "=== package.json version ==="
    node -p "require('./package.json').version" 2>/dev/null || echo "(unavailable)"
