# frozen_string_literal: true

require "rake/testtask"

desc "Run StandardRB linter"
task :lint do
  sh "bundle exec standardrb"
end

desc "Build gem into pkg/"
task :build do
  require_relative "lib/bt_publishing_test/version"
  sh "gem build bt-publishing-test.gemspec"
  mkdir_p "pkg"
  mv "bt-publishing-test-#{BtPublishingTest::VERSION}.gem", "pkg/"
end

namespace :release do
  task publish: [:lint, :build] do
    gem_files = FileList["pkg/bt-publishing-test-*.gem"]
    raise "No gem file found after build" if gem_files.empty?

    if ENV["DRY_RUN"] == "true"
      puts "DRY RUN: would push #{gem_files.first} to RubyGems (skipped)"
    else
      sh "gem push #{gem_files.first}"
      puts "✓ Gem pushed to RubyGems"
    end
  end

  task :push_tag do
    require_relative "lib/bt_publishing_test/version"
    tag = "v#{BtPublishingTest::VERSION}"
    if ENV["DRY_RUN"] == "true"
      puts "DRY RUN: would push tag #{tag} to origin (skipped)"
    else
      sh "git tag #{tag}"
      sh "git push origin #{tag}"
      puts "✓ Tag #{tag} pushed"
    end
  end
end

# Called by rubygems/release-gem in the release workflow.
# bt-publishing-test: tag push omitted to avoid tag pollution from repeated test runs.
# In real SDK workflows, include "release:push_tag" here.
task release: ["release:publish"] do
  puts "✓ Release complete"
end
